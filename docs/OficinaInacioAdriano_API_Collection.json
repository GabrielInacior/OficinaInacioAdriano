{
  "info": {
    "name": "Oficina Inácio & Adriano - API",
    "description": "Coleção completa de testes para todas as rotas da API REST.\n\n## Como usar:\n1. Importe no Postman ou Insomnia\n2. Execute 'Auth > Register' para criar usuário\n3. Execute 'Auth > Login' para obter o token JWT\n4. O token é salvo automaticamente na variável {{token}}\n5. Todas as outras requisições usam {{token}} no header Authorization",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "token", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "🔐 Auth",
      "description": "Autenticação e gerenciamento de conta",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Administrador\",\n  \"email\": \"admin@oficina.com\",\n  \"senha\": \"123456\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.test('Registro OK', () => { pm.response.to.have.status(201); });",
                  "  const body = pm.response.json();",
                  "  pm.test('Retorna id', () => { pm.expect(body.id).to.be.a('number'); });",
                  "  pm.test('Retorna nome', () => { pm.expect(body.nome).to.eql('Administrador'); });",
                  "  pm.test('Retorna email', () => { pm.expect(body.email).to.eql('admin@oficina.com'); });",
                  "  pm.test('Retorna role USER', () => { pm.expect(body.role).to.eql('USER'); });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@oficina.com\",\n  \"senha\": \"123456\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login OK', () => { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('Retorna token', () => { pm.expect(body.token).to.be.a('string'); });",
                  "pm.test('Tipo Bearer', () => { pm.expect(body.tipo).to.eql('Bearer'); });",
                  "pm.collectionVariables.set('token', body.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login - Credenciais Inválidas",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@oficina.com\",\n  \"senha\": \"senhaerrada\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Retorna 401', () => { pm.response.to.have.status(401); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/auth/profile", "host": ["{{baseUrl}}"], "path": ["api","auth","profile"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Perfil OK', () => { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('Tem nome', () => { pm.expect(body.nome).to.be.a('string'); });",
                  "pm.test('Tem email', () => { pm.expect(body.email).to.be.a('string'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Admin Atualizado\",\n  \"email\": \"admin@oficina.com\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/profile", "host": ["{{baseUrl}}"], "path": ["api","auth","profile"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Atualização OK', () => { pm.response.to.have.status(200); });",
                  "pm.test('Nome atualizado', () => { pm.expect(pm.response.json().nome).to.eql('Admin Atualizado'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"senhaAtual\": \"123456\",\n  \"novaSenha\": \"654321\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/password", "host": ["{{baseUrl}}"], "path": ["api","auth","password"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Senha alterada', () => { pm.response.to.have.status(204); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Profile - Sem Token (401)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/auth/profile", "host": ["{{baseUrl}}"], "path": ["api","auth","profile"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Bloqueado sem token', () => { pm.response.to.have.status(401).or.to.have.status(403); });"
                ]
              }
            }
          ]
        }
      ]
    },
