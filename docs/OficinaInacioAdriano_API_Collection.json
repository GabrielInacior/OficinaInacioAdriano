          "event": [{ "listen": "test", "script": { "exec": ["pm.test('200 OK', () => pm.response.to.have.status(200));","pm.test('É array', () => pm.expect(pm.response.json()).to.be.an('array'));"] } }]
        },
        {
          "name": "Create (vincular peça à OS)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"codOrdem\": 1,\n  \"codPeca\": 1,\n  \"quantidade\": 2,\n  \"valorCobrado\": 89.80\n}" },
            "url": { "raw": "{{baseUrl}}/api/pecas-os", "host": ["{{baseUrl}}"], "path": ["api","pecas-os"] }
          },
          "event": [{ "listen": "test", "script": { "exec": ["if(pm.response.code===201){pm.test('201 Created', () => pm.response.to.have.status(201));}"] } }]
        },
        {
          "name": "Delete (desvincular)",
          "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/api/pecas-os/1/1", "host": ["{{baseUrl}}"], "path": ["api","pecas-os","1","1"] } },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('204 No Content', () => pm.response.to.have.status(204));"] } }]
        }
      ]
    }
  ]
